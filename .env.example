# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# From `npm run stripe:listen` locally, or Stripe Dashboard → Webhooks in production
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (optional — order confirmation + icon ZIP emails)
# https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM=Iconify <onboarding@resend.dev>

# Public app URL (Stripe redirect URLs + email links)
APP_URL=http://localhost:3000

# Noun Project (https://thenounproject.com/developers)
NOUN_PROJECT_API_KEY=
NOUN_PROJECT_API_SECRET=

# Set to true only for UI-only dev without Stripe (instant mock unlock)
VITE_USE_MOCK_CHECKOUT=false

# Leave empty when using `vercel dev` (API served on same origin)
# VITE_API_BASE=

# Firebase (https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
